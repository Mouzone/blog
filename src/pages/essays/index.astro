---
import { getCollection } from "astro:content";
import Boilerplate from "../../layouts/Boilerplate.astro";

const essays = await getCollection("essays")
---
<Boilerplate>
    {
        essays.map(essay => (
            <li><a href={`/essays/${essay.id}`}>{essay.data.title}</a></li>
        ))
    }
</Boilerplate>
